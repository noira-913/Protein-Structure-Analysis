# Build artifacts
build/
dist/
*.egg-info/

# Compiled extensions (built inplace by setup.py)
*.pyc
*.pyo
__pycache__/
*.so
*.pyd
# nvcc builds protein_physics_cuda directly (setup.py's build_cuda_extension()
# shells out to nvcc/cl.exe, bypassing setuptools), which can drop these
# root-level .exp/.lib/.obj byproducts next to the .pyd.
*.exp
*.lib
*.obj

# Downloaded structure files (fetched at runtime, not committed) -- except a
# curated set of test fixtures that ARE tracked (e.g. data/1XQ8.pdb, used by
# IMPROVEMENTS.md's IDP calibration history); git keeps tracking files that
# were already added before this rule existed, so this only affects new ones.
*.ent
data/*.pdb

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
build.ninja

# Editor / OS
.idea/
.vscode/
*.DS_Store
Thumbs.db

# Logs
error_log.txt

# Claude Code local tooling state (worktrees, session config)
.claude/

# One-off validation/probe scripts (referenced by name only in
# IMPROVEMENTS.md, never committed -- e.g. autocorr_probe.py,
# pivot_branch_validation.py, ensemble_metrics_validation.py)
scratchpad/
